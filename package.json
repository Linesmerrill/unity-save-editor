{
  "name": "unity-save-editor",
  "version": "1.0.0",
  "description": "Drag-and-drop editor for Unity .dat save files",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "dist:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.unitysaveeditor.app",
    "productName": "Unity Save Editor",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ]
  },
  "keywords": ["unity", "save", "editor", "game"],
  "author": "linesmerrill",
  "repository": {
    "type": "git",
    "url": "https://github.com/linesmerrill/unity-save-editor.git"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
